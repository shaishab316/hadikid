model School {
  id String @id @default(uuid())

  name String?

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  photoId String?
  photo   Media?  @relation("school_photo", fields: [photoId], references: [id], onDelete: SetNull)

  bannerId String?
  banner   Media?  @relation("school_banner", fields: [bannerId], references: [id], onDelete: SetNull)

  children Child[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([photoId])
  @@index([bannerId])
  @@map("schools")
}
