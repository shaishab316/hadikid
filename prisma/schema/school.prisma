// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL
// ─────────────────────────────────────────────────────────────────────────────

model School {
    id String @id @default(uuid())

    name String @unique

    locationId String?
    location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

    photoId String?
    photo   Media?  @relation("school_photo", fields: [photoId], references: [id], onDelete: SetNull)

    bannerId String?
    banner   Media?  @relation("school_banner", fields: [bannerId], references: [id], onDelete: SetNull)

    phone   String?
    email   String?
    website String?

    isVerified Boolean @default(false)

    children Child[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([locationId])
    @@map("schools")
}
