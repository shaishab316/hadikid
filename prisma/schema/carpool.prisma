model Carpool {
    id String @id @default(uuid())

    title String?

    pickupId String?
    pickup   Location? @relation("carpool_pickup", fields: [pickupId], references: [id], onDelete: SetNull)

    dropoffId String?
    dropoff   Location? @relation("carpool_dropoff", fields: [dropoffId], references: [id], onDelete: SetNull)

    vehicleLocationId String?
    vehicleLocation   Location? @relation("carpool_vehicle_location", fields: [vehicleLocationId], references: [id], onDelete: SetNull)

    repeatRule CarpoolRepeatRule?

    notes String?

    driverId Int?
    driver   User? @relation("carpool_driver", fields: [driverId], references: [id], onDelete: SetNull)

    members CarpoolMember[]
    invites CarpoolInvite[]
    rounds  CarpoolRound[]

    // ===========================

    isDeleted Boolean @default(false)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@index([isDeleted])
    @@index([driverId])
    @@index([pickupId])
    @@index([dropoffId])
    @@index([vehicleLocationId])
    @@map("carpools")
}

model CarpoolMember {
    id String @id @default(uuid())

    carpoolId String
    carpool   Carpool @relation(fields: [carpoolId], references: [id], onDelete: Cascade)

    userId Int
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    children Child[] @relation("carpool_member_children")

    role                          String?
    carpoolRoundPickupChecklists  CarpoolRoundPickupChecklist[]
    carpoolRoundDropoffChecklists CarpoolRoundDropoffChecklist[]

    @@index([carpoolId])
    @@index([userId])
    @@map("carpool_members")
}

model CarpoolInvite {
    id String @id @default(uuid())

    carpoolId String
    carpool   Carpool @relation(fields: [carpoolId], references: [id], onDelete: Cascade)

    userId Int
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    message String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([carpoolId])
    @@index([userId])
    @@map("carpool_invites")
}

model CarpoolRound {
    id String @id @default(uuid())

    carpoolId String
    carpool   Carpool @relation(fields: [carpoolId], references: [id], onDelete: Cascade)

    startAt DateTime
    endAt   DateTime

    status String?

    pickupChecklists              CarpoolRoundPickupChecklist[]
    carpoolRoundDropoffChecklists CarpoolRoundDropoffChecklist[]

    @@index([carpoolId])
    @@index([startAt])
    @@index([endAt])
    @@map("carpool_rounds")
}

model CarpoolRoundPickupChecklist {
    id String @id @default(uuid())

    roundId String
    round   CarpoolRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

    memberId String
    member   CarpoolMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

    childId String
    child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

    // PENDING, PRESENT, ABSENT
    status String?

    @@map("carpool_round_pickup_checklists")
}

model CarpoolRoundDropoffChecklist {
    id String @id @default(uuid())

    roundId String
    round   CarpoolRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

    memberId String
    member   CarpoolMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

    childId String
    child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

    // PENDING, PRESENT, ABSENT
    status String?

    @@map("carpool_round_dropoff_checklists")
}

