// ─────────────────────────────────────────────────────────────────────────────
// CARPOOL
// ─────────────────────────────────────────────────────────────────────────────

model Carpool {
    id    String  @id @default(uuid())
    title String?
    notes String?

    status String

    pickupId String?
    pickup   Location? @relation("carpool_pickup", fields: [pickupId], references: [id], onDelete: SetNull)

    dropoffId String?
    dropoff   Location? @relation("carpool_dropoff", fields: [dropoffId], references: [id], onDelete: SetNull)

    vehicleLocationId String?
    vehicleLocation   Location? @relation("carpool_vehicle_location", fields: [vehicleLocationId], references: [id], onDelete: SetNull)

    driverId Int?
    driver   User? @relation("carpool_driver", fields: [driverId], references: [id], onDelete: SetNull)

    repeatRule CarpoolRepeatRule?
    members    CarpoolMember[]
    invites    CarpoolInvite[]
    rounds     CarpoolRound[]
    reviews    Review[]

    estimatedArrivalTime String?

    conversationId String?       @unique
    conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

    isDeleted Boolean   @default(false)
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@index([status])
    @@index([isDeleted])
    @@index([driverId])
    @@index([pickupId])
    @@index([dropoffId])
    @@map("carpools")
}

// ─────────────────────────────────────────────────────────────────────────────
// CARPOOL MEMBER
// ─────────────────────────────────────────────────────────────────────────────

model CarpoolMember {
    id String @id @default(uuid())

    carpoolId String
    carpool   Carpool @relation(fields: [carpoolId], references: [id], onDelete: Cascade)

    userId Int
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    role String

    children Child[] @relation("carpool_member_children")

    pickupChecklists  CarpoolRoundPickupChecklist[]
    dropoffChecklists CarpoolRoundDropoffChecklist[]

    joinedAt DateTime  @default(now())
    leftAt   DateTime?

    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt

    @@unique([carpoolId, userId])
    @@index([carpoolId])
    @@index([userId])
    @@map("carpool_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// CARPOOL INVITE
// ─────────────────────────────────────────────────────────────────────────────

model CarpoolInvite {
    id String @id @default(uuid())

    carpoolId String
    carpool   Carpool @relation(fields: [carpoolId], references: [id], onDelete: Cascade)

    userId Int
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    /// PENDING | ACCEPTED | DECLINED | CANCELLED
    status String

    message String?

    expiresAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([carpoolId, userId])
    @@index([carpoolId])
    @@index([userId])
    @@index([status])
    @@map("carpool_invites")
}

// ─────────────────────────────────────────────────────────────────────────────
// CARPOOL ROUND  (one trip = one round)
// ─────────────────────────────────────────────────────────────────────────────

model CarpoolRound {
    id String @id @default(uuid())

    carpoolId String
    carpool   Carpool @relation(fields: [carpoolId], references: [id], onDelete: Cascade)

    /// PICKUP | DROPOFF
    type String

    /// SCHEDULED | IN_PROGRESS | COMPLETED | CANCELLED
    status String

    scheduledAt DateTime
    startedAt   DateTime?
    completedAt DateTime?

    pickupChecklists  CarpoolRoundPickupChecklist[]
    dropoffChecklists CarpoolRoundDropoffChecklist[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    driverId Int?
    driver   User? @relation("carpool_round_driver", fields: [driverId], references: [id], onDelete: SetNull)

    @@index([driverId])
    @@index([carpoolId])
    @@index([status])
    @@index([scheduledAt])
    @@map("carpool_rounds")
}

// ─────────────────────────────────────────────────────────────────────────────
// CHECKLISTS  (pickup & dropoff share the same shape)
// ─────────────────────────────────────────────────────────────────────────────

model CarpoolRoundPickupChecklist {
    id String @id @default(uuid())

    roundId String
    round   CarpoolRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

    memberId String
    member   CarpoolMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

    childId String
    child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

    /// PENDING | PRESENT | ABSENT
    status String

    checkedAt DateTime?
    note      String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([roundId, childId])
    @@index([roundId])
    @@index([memberId])
    @@index([childId])
    @@map("carpool_round_pickup_checklists")
}

model CarpoolRoundDropoffChecklist {
    id String @id @default(uuid())

    roundId String
    round   CarpoolRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

    memberId String
    member   CarpoolMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

    childId String
    child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

    /// PENDING | PRESENT | ABSENT
    status String

    checkedAt DateTime?
    note      String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([roundId, childId])
    @@index([roundId])
    @@index([memberId])
    @@index([childId])
    @@map("carpool_round_dropoff_checklists")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPEAT RULE  (RFC 5545 / iCalendar RRULE)
// ─────────────────────────────────────────────────────────────────────────────

model CarpoolRepeatRule {
    id        String  @id @default(uuid())
    carpoolId String  @unique
    carpool   Carpool @relation(fields: [carpoolId], references: [id], onDelete: Cascade)

    // ── Frequency ─────────────────────────────────────────────────────────
    /// DAILY | WEEKLY | MONTHLY | YEARLY
    frequency String

    /// Every N units. interval=2 + WEEKLY = every 2 weeks.
    interval Int @default(1)

    // ── Time ──────────────────────────────────────────────────────────────
    /// 24hr HH:MM local time. e.g. "17:00" = 5 pm. null = all-day.
    timeOfDay String?

    /// IANA timezone. e.g. "Asia/Dhaka" | "America/New_York"
    timezone String @default("UTC")

    // ── Range ─────────────────────────────────────────────────────────────
    startDate DateTime

    /// null = runs forever
    endDate DateTime?

    /// Stop after exactly N occurrences (alternative to endDate)
    maxOccurrences Int?

    // ── Day filter (WEEKLY / DAILY) ───────────────────────────────────────
    /// RFC 5545 day codes, comma-separated: MO TU WE TH FR SA SU
    /// WEEKLY  → "MO,WE,FR" = Mon/Wed/Fri
    /// DAILY   → "MO,TU,WE,TH,SA,SU" = every day except Friday
    byDay String?

    // ── Month-day filter (MONTHLY) ────────────────────────────────────────
    /// Comma-separated integers. Negative = from end.
    /// "1,15" = 1st & 15th | "-1" = last day
    byMonthDay String?

    // ── Nth-weekday filter (MONTHLY) ──────────────────────────────────────
    /// "{n}{day}" e.g. "1MO" = 1st Mon | "-1FR" = last Fri | "2TU,4TU"
    bySetPos String?

    // ── Month filter (YEARLY) ─────────────────────────────────────────────
    /// Comma-separated month numbers 1–12.
    /// "1,4,7,10" = every quarter
    byMonth String?

    // ── Exceptions & extras ───────────────────────────────────────────────
    /// ISO dates to SKIP, comma-separated. e.g. "2025-12-25,2026-01-01"
    exceptionDates String?

    /// One-off extra dates outside the rule. e.g. "2025-11-28"
    extraDates String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("carpool_repeat_rules")
}
