// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
    id Int @id @default(autoincrement())

    /// Auto-generated public slug. e.g. "u-000001"
    slug String? @unique

    name  String?
    email String? @unique
    phone String? @unique

    /// MALE | FEMALE | OTHER
    gender String?
    dob    DateTime?

    emergencyPhone String?

    /// Publicly visible contact info (shown on profile)
    publicPhone String?
    publicEmail String?

    profilePictureId String?
    profilePicture   Media?  @relation("profile_pictures", fields: [profilePictureId], references: [id], onDelete: SetNull)

    // ── Flags ─────────────────────────────────────────────────────────────
    /// ACTIVE | SUSPENDED | BANNED | PENDING
    status String @default("ACTIVE")

    isEmailVerified Boolean @default(false)
    isPhoneVerified Boolean @default(false)
    isFaceVerified  Boolean @default(false)

    isOnline     Boolean  @default(false)
    lastOnlineAt DateTime @default(now())

    // ── Rating (denormalized for fast reads) ──────────────────────────────
    rating      Decimal @default(0.0) @db.Decimal(3, 2)
    ratingCount Int     @default(0)

    // ── Relations ─────────────────────────────────────────────────────────
    auth   Authentication?
    roles  UserRoleMapping[]
    wallet Wallet?

    schoolId String?
    school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

    bio String?

    location          Location?
    locationHistories LocationHistory[]
    savedLocations    SavedLocation[]

    medias Media[]

    devices       UserDevice[]
    notifications Notification[]

    conversationParticipants ConversationParticipant[]
    conversationMessages     ConversationMessage[]

    reviewsGiven    Review[] @relation("review_reviewer")
    reviewsReceived Review[] @relation("review_subject")

    children Child[]

    driverCarpools Carpool[]       @relation("carpool_driver")
    carpoolMembers CarpoolMember[]
    carpoolInvites CarpoolInvite[]

    contactRequestsSent     ContactRequest[] @relation("contact_request_sender")
    contactRequestsReceived ContactRequest[] @relation("contact_request_receiver")
    contacts1               Contact[]        @relation("contacts1")
    contacts2               Contact[]        @relation("contacts2")

    carpoolRounds CarpoolRound[] @relation("carpool_round_driver")

    @@index([slug])
    @@index([email])
    @@index([phone])
    @@index([status])
    @@index([isOnline])
    @@index([lastOnlineAt])
    @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTHENTICATION
// ─────────────────────────────────────────────────────────────────────────────

model Authentication {
    id     String @id @default(uuid())
    userId Int    @unique

    passwordHash String?

    lastLoginAt          DateTime?
    lastPasswordChangeAt DateTime?

    wrongPasswordAttempts Int       @default(0)
    lockedUntil           DateTime? // null = not locked

    canLogin           Boolean @default(true)
    mustChangePassword Boolean @default(false)

    twoFactorEnabled Boolean @default(false)
    twoFactorSecret  String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([canLogin])
    @@index([lockedUntil])
    @@index([lastLoginAt])
    @@map("authentications")
}

// ─────────────────────────────────────────────────────────────────────────────
// ROLES
// ─────────────────────────────────────────────────────────────────────────────

model UserRoleMapping {
    id     String @id @default(uuid())
    userId Int

    /// UserRole
    role String

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, role])
    @@index([userId])
    @@index([role])
    @@map("user_role_mappings")
}
