model Media {
  id String @id @default(uuid())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  url              String
  type             String
  mimeType         String?
  previewUrl       String?
  bytes            String?
  width            Int?
  height           Int?
  provider         String?
  providerPublicId String?
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ttl DateTime?

  messageAttachments ConversationMessage[] @relation("message_attachments")

  profilePictureOfUsers User[]         @relation("profile_pictures")
  conversations         Conversation[] @relation("conversation_image")

  schoolPhotos  School[] @relation("school_photo")
  schoolBanners School[] @relation("school_banner")

  childPhotos Child[] @relation("child_photo")

  @@index([userId])
  @@index([type, createdAt])
  @@index([ttl])
  @@map("medias")
}
