// ─────────────────────────────────────────────────────────────────────────────
// CHILD
// ─────────────────────────────────────────────────────────────────────────────

model Child {
    id String @id @default(uuid())

    name String
    dob  DateTime?

    /// School grade/class. e.g. "Grade 3", "Year 5"
    grade String?

    /// PARENT | GUARDIAN | GRANDPARENT | OTHER
    relationship String?

    parentId Int
    parent   User @relation(fields: [parentId], references: [id], onDelete: Cascade)

    schoolId String?
    school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

    photoId String?
    photo   Media?  @relation("child_photo", fields: [photoId], references: [id], onDelete: SetNull)

    carpoolMembers                CarpoolMember[]              @relation("carpool_member_children")
    carpoolRoundPickupChecklists  CarpoolRoundPickupChecklist[]
    carpoolRoundDropoffChecklists CarpoolRoundDropoffChecklist[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([parentId])
    @@index([schoolId])
    @@map("children")
}
