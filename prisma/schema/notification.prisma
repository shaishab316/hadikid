model Notification {
  id String @id @default(ulid())

  title   String?
  message String

  isRead Boolean @default(false)

  type String?

  app String?

  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}
