// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
    id String @id @default(uuid())

    userId Int
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    title   String?
    message String

    /// CARPOOL_INVITE | CARPOOL_ROUND_STARTED | CARPOOL_ROUND_COMPLETED
    /// CONTACT_REQUEST | MESSAGE | SYSTEM | WALLET
    type String

    /// Deep-link target. e.g. "/carpool/abc123"
    actionUrl String?

    /// Arbitrary payload for the client
    metadata Json @default("{}")

    isRead  Boolean   @default(false)
    readAt  DateTime?

    createdAt DateTime @default(now())

    @@index([userId])
    @@index([userId, isRead])
    @@index([type])
    @@index([createdAt])
    @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER DEVICE  (push notification targets)
// ─────────────────────────────────────────────────────────────────────────────

model UserDevice {
    id String @id @default(uuid())

    userId Int
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    /// FCM | APNS | ONESIGNAL
    provider String @default("ONESIGNAL")

    /// The push token / player ID for this device
    token String

    /// ios | android | web
    platform String?

    deviceName String?

    isActive Boolean @default(true)

    lastSeenAt DateTime @default(now())
    createdAt  DateTime @default(now())

    @@unique([userId, token])
    @@index([userId])
    @@index([isActive])
    @@map("user_devices")
}
