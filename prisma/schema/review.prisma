// ─────────────────────────────────────────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────────────────────────────────────────

model Review {
    id String @id @default(uuid())

    ///  USER | CARPOOL
    type String

    rating  Decimal @db.Decimal(2, 1)
    comment String?

    reviewerId Int?
    reviewer   User? @relation("review_reviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

    /// The user being reviewed (null for carpool reviews)
    subjectId Int?
    subject   User? @relation("review_subject", fields: [subjectId], references: [id], onDelete: SetNull)

    /// Optional: which carpool this review is about
    carpoolId String?
    carpool   Carpool? @relation(fields: [carpoolId], references: [id], onDelete: SetNull)

    metadata Json @default("{}")

    createdAt DateTime  @default(now())
    updatedAt DateTime? @updatedAt

    @@index([reviewerId])
    @@index([subjectId])
    @@index([type])
    @@index([carpoolId])
    @@index([rating, subjectId])
    @@index([rating, carpoolId])
    @@map("reviews")
}
