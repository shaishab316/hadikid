// ─────────────────────────────────────────────────────────────────────────────
// WALLET
// ─────────────────────────────────────────────────────────────────────────────

model Wallet {
    id String @id @default(uuid())

    userId Int  @unique
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    balance  Decimal @default(0) @db.Decimal(12, 2)

    /// ISO 4217 currency code. e.g. "USD" | "BDT" | "GBP"
    currency String @default("USD")

    /// ACTIVE | SUSPENDED | FROZEN
    status String @default("ACTIVE")

    transactions WalletTransaction[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([status])
    @@map("wallets")
}

// ─────────────────────────────────────────────────────────────────────────────
// WALLET TRANSACTION
// ─────────────────────────────────────────────────────────────────────────────

model WalletTransaction {
    id String @id @default(uuid())

    walletId String
    wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

    /// CREDIT | DEBIT
    direction String

    amount  Decimal @db.Decimal(12, 2)
    balance Decimal @db.Decimal(12, 2) // balance AFTER this transaction

    /// TOP_UP | WITHDRAWAL | CARPOOL_PAYMENT | REFUND | ADJUSTMENT
    type String

    /// Reference ID from external payment provider
    referenceId String?

    description String?

    metadata Json @default("{}")

    /// PENDING | COMPLETED | FAILED | REVERSED
    status String @default("COMPLETED")

    createdAt DateTime @default(now())

    @@index([walletId])
    @@index([walletId, createdAt])
    @@index([type])
    @@index([status])
    @@map("wallet_transactions")
}
