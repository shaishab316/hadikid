# ============================================
# SERVER CONFIGURATION EXAMPLE
# ============================================

# Environment mode
# Values: development, test, production
# Default: development
NODE_ENV=development

# Server port
# Values: 1000-65535 (integer)
# Default: 3000
PORT=3000

# Allowed CORS origins
# - Use "*" to allow all origins (not recommended for production)
# - Use comma-separated list of URLs: https://app.example.com,https://admin.example.com
# Default: *
CORS_ORIGIN=*

# ============================================
# DATABASE (PostgreSQL)
# ============================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# Required: Yes
DATABASE_URL=postgresql://postgres:password@localhost:5432/mydb

# ============================================
# REDIS (Cache & Queue)
# ============================================

# Redis connection URL
# Format: redis://[:password@]host:port[/database]
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ============================================
# JWT AUTHENTICATION
# ============================================

# JWT signing secret
# Requirements: Minimum 32 characters
# Generate: openssl rand -base64 32
# Required: Yes
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# JWT token expiration time
# Format: Number + unit (d=days, h=hours, m=minutes, s=seconds)
# Examples: 7d, 24h, 90m, 3600s
# Default: 7d
JWT_EXPIRES_IN=7d

# Base secret for OTP generation
# Requirements: Minimum 10 characters
# Required: Yes
OTP_SECRET=otp-secret-min-10-chars

# Test OTP (for development only)
# Fixed OTP for testing purposes - DO NOT use in production
# Default: 123456
TEST_OTP=123456

# ============================================
# STRIPE PAYMENT GATEWAY
# ============================================

# Stripe secret API key
# Format: Must start with "sk_"
# Required: Yes
STRIPE_SECRET_KEY=

# Stripe publishable API key
# Format: Must start with "pk_"
# Required: Yes
STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret
# Format: Must start with "whsec_"
# Required: Yes
STRIPE_WEBHOOK_SECRET=

# ============================================
# CLOUDINARY (Media Storage)
# ============================================

# Cloudinary cloud name
# Required: Yes
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary API key
# Required: Yes
CLOUDINARY_API_KEY=123456789012345

# Cloudinary API secret
# Required: Yes
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================
# EMAIL (Nodemailer SMTP)
# ============================================

# SMTP server host
# Examples: smtp.gmail.com, smtp.sendgrid.net, mail.yourdomain.com
# Required: Yes
SMTP_HOST=smtp.gmail.com

# SMTP server port
# Common ports: 587 (TLS), 465 (SSL), 25 (unencrypted)
# Default: 587
SMTP_PORT=587

# SMTP authentication email
# Format: Must be a valid email address
# Required: Yes
SMTP_USER=user@example.com

# SMTP authentication password
# Required: Yes
SMTP_PASSWORD=your-smtp-password

# Email sender address
# Format: Must be a valid email address
# Required: Yes
SMTP_FROM_EMAIL=noreply@yourapp.com

# Email sender name
# Default: hadikid
SMTP_FROM_NAME=hadikid

# ============================================
# ADMIN USER (Initial Setup)
# ============================================

# Admin email address
# Format: Must be a valid email address
# Required: Yes
ADMIN_EMAIL=admin@example.com

# Admin initial password
# Requirements: Minimum 6 characters
# Required: Yes
ADMIN_PASSWORD=admin123

# ============================================
# LOGGING & MONITORING
# ============================================

# Logging level
# Values: error, warn, log, debug, verbose
# Default: log
LOG_LEVEL=log

# Loki logging server URL
# For centralized log aggregation
# Default: http://localhost:3100
LOKI_URL=http://localhost:3100

# ============================================
# PUSH NOTIFICATIONS (OneSignal)
# ============================================

# OneSignal REST API key
# Required: Yes
ONESIGNAL_API_KEY=your-onesignal-api-key

# OneSignal App ID
# Required: Yes
ONESIGNAL_APP_ID=your-onesignal-app-id

# ============================================
# PROTECTED ROUTES (Authentication for internal tools)
# ============================================

# Username for API documentation access (/docs route)
# Required: Yes
DOCS_USERNAME=admin

# Password for API documentation access (/docs route)
# Requirements: Minimum 6 characters
# Required: Yes
DOCS_PASSWORD=docs123

# Username for Bull Board queue admin access (/queues route)
# Required: Yes
QUEUES_USERNAME=admin

# Password for Bull Board queue admin access (/queues route)
# Requirements: Minimum 6 characters
# Required: Yes
QUEUES_PASSWORD=queues123