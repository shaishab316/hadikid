# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/hadikid

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-with-at-least-32-characters
JWT_EXPIRES_IN=7d
OTP_SECRET=your-otp-secret-min-10-chars

# ============================================
# STRIPE PAYMENT
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# CLOUDINARY MEDIA
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================
# EMAIL (Nodemailer SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@hadikid.com
SMTP_FROM_NAME=hadikid

# ============================================
# ADMIN USER
# ============================================
ADMIN_EMAIL=admin@hadikid.com
ADMIN_PASSWORD=SecureAdminPass123

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=log
LOKI_URL=http://localhost:3100

# ============================================
# PUSH NOTIFICATIONS (OneSignal)
# ============================================
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-rest-api-key

# ============================================
# PROTECTED ROUTES (Docs & Queues)
# ============================================
DOCS_USERNAME=admin
DOCS_PASSWORD=secure-docs-password-123
QUEUES_USERNAME=admin
QUEUES_PASSWORD=secure-queues-password-123

# ============================================
# TESTING (Optional - DO NOT use in production)
# ============================================
TEST_OTP=1234